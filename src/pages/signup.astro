---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Sign Up for a Workshop - WishesMadeClear">
  <Header />
  <main>
    <section class="signup-section">
      <div class="signup-container">
        <h1>Get Updates on Upcoming End of Life Planning Workshops</h1>

        <div class="intro-text">
          <p>We're hosting workshops to help you document your wishes clearly. Sessions are available in person in Austin and Bastrop, or join us for a Zoom series from anywhere. These are small group workshops where you'll have space to work through each topic at your own pace.</p>

          <p>Our in-person Austin workshops meet near Zilker in the 78704 area, and our Bastrop sessions are held in downtown Bastrop, Texas 78602. Whether you're local to Central Texas or joining remotely, you'll get the same guided support to create your advance directives and organize your estate planning documents.</p>
        </div>

        <div class="pilot-fee-notice">
          <p>This is a pilot. We will collect a $100 registration fee which can be returned to you or donated upon completion of the workshop.</p>
        </div>

        <form action="https://api.web3forms.com/submit" method="POST" class="signup-form" id="signup-form">
          <!-- Web3Forms required fields (TODO: Add your access_key) -->
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY_HERE">
          <input type="hidden" name="subject" value="New Workshop Signup - WishesMadeClear">
          <input type="hidden" name="from_name" value="WishesMadeClear Website">

          <!-- Honeypot spam protection -->
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

          <!-- Contact Information -->
          <div class="form-section">
            <h2>Contact Information</h2>

            <div class="form-group">
              <label for="email">Email <span class="required">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                aria-required="true"
                placeholder="your@email.com"
              >
            </div>

            <div class="form-group">
              <label for="phone">Phone <span class="required">*</span></label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                aria-required="true"
                placeholder="(512) 555-1234"
              >
            </div>
          </div>

          <!-- Workshop Preferences -->
          <div class="form-section">
            <h2>Workshop Preference</h2>
            <p class="section-note">Select all that interest you</p>

            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" name="workshop_preference" value="In person Austin">
                <span>In person Austin</span>
              </label>

              <label class="checkbox-label">
                <input type="checkbox" name="workshop_preference" value="In person Bastrop">
                <span>In person Bastrop</span>
              </label>

              <label class="checkbox-label">
                <input type="checkbox" name="workshop_preference" value="Zoom">
                <span>Zoom</span>
              </label>
            </div>
          </div>

          <!-- Optional Notes -->
          <div class="form-section">
            <div class="form-group">
              <label for="notes">Questions or Notes <span class="optional">(optional)</span></label>
              <textarea
                id="notes"
                name="notes"
                rows="4"
                placeholder="Any questions or special needs we should know about?"
              ></textarea>
            </div>
          </div>

          <!-- Privacy Note -->
          <p class="privacy-note">We respect your privacy. We do not sell your information.</p>

          <!-- Submit Button -->
          <button type="submit" class="btn btn-primary btn-submit">Submit</button>

          <!-- Success Message (hidden by default) -->
          <div id="success-message" class="success-message" style="display: none;">
            <p>Congratulations on taking this step towards making your wishes clear.</p>
          </div>
        </form>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .signup-section {
    background: var(--bg);
    padding: var(--section-padding) 0;
  }

  .signup-container {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  h1 {
    text-align: center;
    margin-bottom: 2rem;
  }

  .intro-text {
    margin-bottom: 2rem;
  }

  .intro-text p {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .pilot-fee-notice {
    background: var(--bg-alt);
    padding: 1.25rem;
    border-radius: var(--radius-md);
    border-left: 4px solid var(--sage-dark);
    margin: 1.5rem 0 2rem;
  }

  .pilot-fee-notice p {
    margin: 0;
    font-weight: 500;
  }

  .signup-form {
    background: var(--surface);
    padding: 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
  }

  .form-section {
    margin-bottom: 2rem;
  }

  .form-section h2 {
    font-size: 1.375rem;
    margin-bottom: 0.5rem;
  }

  .section-note {
    font-size: 0.9375rem;
    color: var(--ink-muted);
    margin-bottom: 1rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  label {
    display: block;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--ink);
  }

  .required {
    color: var(--brand-2);
  }

  .optional {
    font-weight: 400;
    color: var(--ink-muted);
  }

  input[type="email"],
  input[type="tel"],
  textarea {
    width: 100%;
    padding: 0.75rem;
    border: 2px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--ink);
    background: var(--surface);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--brand-1);
    box-shadow: 0 0 0 3px var(--focus);
  }

  textarea {
    resize: vertical;
    min-height: 100px;
  }

  .checkbox-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 400;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: var(--radius-sm);
    transition: background 0.2s ease;
  }

  .checkbox-label:hover {
    background: rgba(64, 32, 77, 0.03);
  }

  .checkbox-label input[type="checkbox"] {
    width: auto;
    margin: 0;
    cursor: pointer;
    width: 20px;
    height: 20px;
  }

  .privacy-note {
    font-size: 0.9375rem;
    color: var(--ink-muted);
    text-align: center;
    margin: 1.5rem 0;
  }

  .btn-submit {
    width: 100%;
    font-size: 1.125rem;
    padding: 1rem;
  }

  .success-message {
    margin-top: 1.5rem;
    padding: 1.25rem;
    background: var(--sage-dark);
    color: white;
    border-radius: var(--radius-md);
    text-align: center;
    font-weight: 600;
  }

  .success-message p {
    margin: 0;
  }

  .hidden {
    display: none !important;
  }

  @media (max-width: 768px) {
    .signup-form {
      padding: 1.5rem;
    }
  }
</style>

<script>
  // Form submission handling
  const form = document.getElementById('signup-form') as HTMLFormElement;
  const successMessage = document.getElementById('success-message');

  if (form && successMessage) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const submitButton = form.querySelector('.btn-submit') as HTMLButtonElement;

      // Disable button during submission
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = 'Submitting...';
      }

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });

        const data = await response.json();

        if (data.success) {
          // Show success message
          form.style.display = 'none';
          successMessage.style.display = 'block';

          // Scroll to success message
          successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error('Form submission failed');
        }
      } catch (error) {
        alert('There was a problem submitting your form. Please try again or email us directly.');

        // Re-enable button
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = 'Submit';
        }
      }
    });
  }
</script>
