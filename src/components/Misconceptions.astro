---
import { misconceptions } from '../content/siteCopy';
---

<section class="misconceptions-section">
  <div class="container">
    <h2>Common Misconceptions About End of Life Planning</h2>
    <div class="misconceptions-grid">
      {misconceptions.map((item) => (
        <div class="misconception-card">
          <div class="myth">
            <span class="icon">✗</span>
            <h3>"{item.myth}"</h3>
          </div>
          <div class="reality">
            <span class="icon">✓</span>
            <p>{item.reality}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .misconceptions-section {
    background: var(--surface);
  }

  .misconceptions-section h2 {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .misconceptions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .misconception-card {
    background: var(--bg);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-subtle);
    border: 1px solid var(--border);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .misconception-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .myth {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 2px solid var(--border);
  }

  .myth h3 {
    color: var(--ink-muted);
    font-size: 1.125rem;
    font-weight: 600;
    font-style: normal;
  }

  .myth .icon {
    display: inline-block;
    color: var(--brand-soft);
    font-size: 1.5rem;
    margin-right: 0.5rem;
    font-weight: bold;
    opacity: 0.8;
  }

  .reality {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .reality .icon {
    color: var(--sage-dark);
    font-size: 1.5rem;
    font-weight: bold;
    flex-shrink: 0;
  }

  .reality p {
    color: var(--ink);
    font-weight: 500;
    margin: 0;
  }

  @media (max-width: 768px) {
    .misconceptions-grid {
      grid-template-columns: 1fr;
    }
  }


  @media (prefers-reduced-motion: reduce) {
    .misconception-card {
      transition: none;
    }

    .misconception-card:hover {
      transform: none;
    }
  }
</style>
