---
import { misconceptions } from '../content/siteCopy';
---

<section class="misconceptions-section">
  <div class="container">
    <h2>Common Misconceptions About End of Life Planning</h2>
    <div class="misconceptions-grid">
      {misconceptions.map((item) => (
        <div class="misconception-card">
          <div class="myth">
            <div class="icon-label-wrapper">
              <img src="/images/icons/myth-unicorn.svg" alt="" class="icon" />
              <span class="label">Myth</span>
            </div>
            <h3>"{item.myth}"</h3>
          </div>
          <div class="reality">
            <div class="icon-label-wrapper">
              <img src="/images/icons/reality-tree.svg" alt="" class="icon" />
              <span class="label">Reality</span>
            </div>
            <p>{item.reality}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .misconceptions-section {
    background: var(--surface);
  }

  .misconceptions-section h2 {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .misconceptions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .misconception-card {
    background: var(--bg);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-subtle);
    border: 1px solid var(--border);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    display: flex;
    flex-direction: column;
    min-height: 400px;
  }

  .misconception-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
    border-color: var(--border-strong);
  }

  .icon-label-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .icon-label-wrapper .icon {
    width: 60px;
    height: 60px;
    display: block;
  }

  .icon-label-wrapper .label {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-muted);
    opacity: 0.6;
  }

  .myth {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--border);
  }

  .myth h3 {
    color: var(--ink-muted);
    font-size: 1.125rem;
    font-weight: 600;
    font-style: normal;
    text-align: justify;
    margin: 0;
  }

  .reality {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .reality p {
    color: var(--ink);
    font-weight: 500;
    margin: 0;
    text-align: justify;
  }

  @media (max-width: 768px) {
    .misconceptions-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .misconceptions-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .misconception-card {
      transition: none;
    }

    .misconception-card:hover {
      transform: none;
    }
  }
</style>
