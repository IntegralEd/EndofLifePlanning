---
import { hero } from '../content/siteCopy';
---

<section class="hero">
  <div class="container">
    <h1>{hero.heading}</h1>
    <p class="tagline">{hero.tagline}</p>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--brand-1) 0%, var(--brand-2) 100%);
    color: white;
    text-align: center;
    padding: var(--section-padding) 0;
  }

  .hero h1 {
    color: white;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .tagline {
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    opacity: 0.95;
    max-width: 700px;
    margin: 0 auto;
    font-weight: 400;
  }
</style>
