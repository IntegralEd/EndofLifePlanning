---
import { hero } from '../content/siteCopy';
---

<section class="hero">
  <div class="container">
    <h1>{hero.heading}</h1>
    <h2 class="subheading">{hero.subheading}</h2>
    <p class="boundary-text">{hero.boundaryText}</p>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--brand-1) 0%, var(--brand-2) 100%);
    color: white;
    text-align: center;
    padding: var(--section-padding) 0;
  }

  .hero h1 {
    color: white;
    margin-bottom: 1.5rem;
    font-weight: 600;
    font-size: clamp(2rem, 4vw, 2.5rem);
  }

  .subheading {
    color: white;
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 400;
    opacity: 0.95;
    max-width: 700px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .boundary-text {
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    font-style: italic;
  }
</style>
