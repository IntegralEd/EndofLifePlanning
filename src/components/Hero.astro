---
import { hero } from '../content/siteCopy';
---

<section class="hero">
  <div class="container">
    <h1>{hero.heading}</h1>
    <p class="tagline">{hero.tagline}</p>
    <p class="support-text">{hero.supportText}</p>
    <p class="boundary-text">{hero.boundaryText}</p>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--brand-1) 0%, var(--brand-2) 100%);
    color: white;
    text-align: center;
    padding: var(--section-padding) 0;
  }

  .hero h1 {
    color: white;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .tagline {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 500;
    opacity: 0.95;
    max-width: 700px;
    margin: 0 auto 2rem;
  }

  .support-text {
    font-size: clamp(1rem, 2vw, 1.125rem);
    opacity: 0.95;
    max-width: 650px;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
  }

  .boundary-text {
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    font-style: italic;
  }
</style>
