---
import { hero } from '../content/siteCopy';
---

<section class="hero">
  <div class="container">
    <h1>{hero.heading}</h1>
    <h2 class="subheading">{hero.subheading}</h2>
    <p class="boundary-statement">{hero.boundaryStatement}</p>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--brand-1) 0%, var(--brand-2) 100%);
    color: white;
    text-align: center;
    padding: var(--section-padding) 0;
  }

  .hero h1 {
    color: white;
    margin-bottom: 1.5rem;
    font-weight: 600;
    font-size: clamp(2rem, 4vw, 2.5rem);
  }

  .subheading {
    color: white;
    font-family: var(--font-body);
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    font-weight: 400;
    opacity: 0.95;
    max-width: 700px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .boundary-statement {
    color: white;
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 1.5vw, 1rem);
    font-weight: 400;
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    border: 2px solid rgba(255, 255, 255, 0.4);
    border-radius: var(--radius-md);
    line-height: 1.5;
  }
</style>
