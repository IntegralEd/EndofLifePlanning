---
import { footer } from '../content/siteCopy';
---

<footer class="site-footer">
  <div class="container">
    <blockquote class="closing-quote">
      "{footer.quote}"
    </blockquote>
    <p class="copyright">{footer.copyright}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink-2);
    color: white;
    padding: 3rem 0 2rem;
    text-align: center;
  }

  .closing-quote {
    font-family: var(--font-head);
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-style: italic;
    font-weight: 500;
    margin-bottom: 2rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.65;
    opacity: 0.95;
  }

  .copyright {
    font-size: var(--text-small);
    opacity: 0.8;
    margin: 0;
  }
</style>
