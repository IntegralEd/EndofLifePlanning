---
// Simple header: full-height logo left, single signup link right
---

<header class="site-header">
  <div class="header-container">
    <a href="/" class="logo-link" aria-label="WishesMadeClear Home">
      <img
        src="/images/logo.png"
        alt="WishesMadeClear - End of Life Planning Workshops"
        class="site-logo"
      />
    </a>

    <a href="/signup" class="signup-link">Sign Up for a Workshop</a>
  </div>
</header>

<style>
  .site-header {
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 100;
    margin: 0;
    padding: 0;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    min-height: 100px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    height: 100%;
  }

  .site-logo {
    height: 100%;
    max-height: 80px;
    width: auto;
    display: block;
  }

  .signup-link {
    color: var(--ink-nav);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    border: 2px solid var(--ink-nav);
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .signup-link:hover {
    color: var(--surface);
    background: var(--ink-nav);
    text-decoration: none;
  }

  .signup-link:focus-visible {
    outline: 3px solid var(--focus);
    outline-offset: 2px;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .header-container {
      min-height: 80px;
      padding: 0.75rem 1rem;
    }

    .site-logo {
      max-height: 60px;
    }

    .signup-link {
      font-size: 0.875rem;
      padding: 0.625rem 1rem;
    }
  }

  @media (max-width: 480px) {
    .header-container {
      gap: 1rem;
    }

    .signup-link {
      font-size: 0.8125rem;
      padding: 0.5rem 0.75rem;
    }
  }
</style>
