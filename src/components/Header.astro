---
// Header with WishesMadeClear logo - full bleed
---

<header class="site-header">
  <img
    src="/images/logo.png"
    alt="WishesMadeClear"
    class="site-logo"
  />
</header>

<style>
  .site-header {
    background: var(--bg);
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1rem 0;
    margin: 0;
    border-bottom: 1px solid var(--border);
  }

  .site-logo {
    width: 100%;
    height: auto;
    display: block;
    max-width: 100%;
  }
</style>
