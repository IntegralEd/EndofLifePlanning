---
import { carouselPrompts } from '../content/siteCopy';
---

<section class="qa-section">
  <div class="container">
    <h2>Can you benefit from this workshop?</h2>
    <p class="qa-intro">Click a question to see the follow-up and consider how you would respond.</p>
    <div class="qa-grid">
      {carouselPrompts.map((prompt) => (
        <details class="qa-card">
          <summary class="qa-card-summary">
            <span class="qa-card-label">Question</span>
            <p class="qa-card-question">{prompt.front}</p>
            <span class="qa-card-helper">Click to reveal a follow-up</span>
          </summary>
          <div class="qa-card-body">
            <span class="qa-card-label qa-card-label-followup">Follow-up</span>
            <p class="qa-card-followup">{prompt.back}</p>
            <div class="qa-card-icon-wrapper">
              <img src={prompt.icon} alt="" class="qa-card-icon" aria-hidden="true" />
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .qa-section {
    background: var(--bg);
  }

  .qa-section h2 {
    text-align: center;
    margin-bottom: 1rem;
  }

  .qa-intro {
    text-align: center;
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: var(--ink-muted);
    max-width: 700px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  /* Grid layout */
  .qa-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 768px) {
    .qa-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .qa-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* Card structure */
  .qa-card {
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: 3 / 4;
    min-height: 400px;
    margin: 0 auto;
    background: white;
    border: 4px solid white;
    border-radius: 18px;
    box-shadow: 0 4px 16px rgba(64, 32, 77, 0.12);
    overflow: hidden;
  }

  .qa-card > summary {
    list-style: none;
    cursor: pointer;
  }

  .qa-card > summary::-webkit-details-marker {
    display: none;
  }

  /* Card inner border and background */
  .qa-card-summary,
  .qa-card-body {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 14px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 30% 30%, rgba(83, 54, 96, 0.08) 0%, transparent 50%),
      var(--ink-2);
  }

  .qa-card-body {
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 250, 246, 0.2) 0%, transparent 50%),
      #F2F1EE;
    border-color: var(--brand-1);
  }

  /* When opened, hide summary and show body */
  .qa-card[open] > summary {
    display: none;
  }

  /* Card labels */
  .qa-card-label {
    position: absolute;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
    opacity: 0.7;
  }

  .qa-card-label-followup {
    color: var(--brand-1);
  }

  /* Card text */
  .qa-card-question {
    font-size: clamp(1.125rem, 2.2vw, 1.375rem);
    font-weight: 600;
    color: white;
    text-align: center;
    margin: 0;
    line-height: 1.6;
  }

  .qa-card-followup {
    font-size: clamp(1.125rem, 2.2vw, 1.375rem);
    font-weight: 400;
    color: var(--ink);
    text-align: center;
    margin: 0;
    line-height: 1.7;
  }

  /* Helper text */
  .qa-card-helper {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.9);
    opacity: 0.7;
    white-space: nowrap;
  }

  /* Icon area */
  .qa-card-icon-wrapper {
    margin-top: 1.5rem;
  }

  .qa-card-icon {
    width: 80px;
    height: 80px;
    display: block;
    opacity: 0.85;
  }

  /* Card body is clickable to flip back */
  .qa-card-body {
    cursor: pointer;
  }

  /* Focus state */
  .qa-card-summary:focus-visible {
    outline: 3px solid var(--focus);
    outline-offset: 4px;
    border-radius: 14px;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .qa-intro {
      margin-bottom: 2rem;
    }

    .qa-grid {
      gap: 1.5rem;
    }

    .qa-card-summary,
    .qa-card-body {
      padding: 2rem 1.5rem;
    }

    .qa-card-question,
    .qa-card-followup {
      font-size: clamp(1rem, 3.5vw, 1.25rem);
    }

    .qa-card-icon {
      width: 70px;
      height: 70px;
    }
  }

  @media (max-width: 480px) {
    .qa-grid {
      gap: 1.25rem;
      padding: 0 0.5rem;
    }

    .qa-card {
      border-radius: 16px;
    }

    .qa-card-summary,
    .qa-card-body {
      padding: 1.75rem 1.5rem;
      border-radius: 12px;
    }

    .qa-card-label {
      top: 1.25rem;
      font-size: 0.6875rem;
    }

    .qa-card-question,
    .qa-card-followup {
      font-size: clamp(0.9375rem, 4vw, 1.125rem);
    }

    .qa-card-helper {
      bottom: 1.25rem;
      font-size: 0.75rem;
    }

    .qa-card-icon-wrapper {
      margin-top: 1.25rem;
    }

    .qa-card-icon {
      width: 60px;
      height: 60px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .qa-card {
      transition: none;
    }
  }
</style>

<script>
  // Allow clicking anywhere on card body to flip back
  const cardBodies = document.querySelectorAll('.qa-card-body');

  cardBodies.forEach(body => {
    body.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();

      const detailsElement = body.closest('details');
      if (detailsElement) {
        detailsElement.open = false;
      }
    });
  });
</script>
