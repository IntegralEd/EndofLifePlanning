---
import { carouselPrompts } from '../content/siteCopy';
---

<section class="carousel-section">
  <div class="container">
    <h2>Can you Benefit from this Workshop?</h2>
    <p class="carousel-intro">Click on these common questions participants discuss and see how you might respond...</p>
    <div class="carousel-container">
      <button class="carousel-btn carousel-btn-prev" aria-label="Previous card">‹</button>
      <div class="carousel-track-container">
        <div class="carousel-track">
          {carouselPrompts.map((prompt) => (
            <div
              class="flip-card"
              data-card-id={prompt.id}
              role="button"
              tabindex="0"
              aria-expanded="false"
              aria-label={`Card ${prompt.id}: ${prompt.front}. Press Enter or Space to reveal follow-up.`}
            >
              <div class="flip-card-inner">
                <!-- Front side -->
                <div class="card-outer card-front-outer">
                  <div class="card-inner">
                    <span class="card-label">Question</span>
                    <p class="card-text">{prompt.front}</p>
                    <span class="card-helper">Click to reveal a follow-up</span>
                  </div>
                </div>
                <!-- Back side -->
                <div class="card-outer card-back-outer">
                  <div class="card-inner">
                    <span class="card-label">Follow-up</span>
                    <p class="card-text">{prompt.back}</p>
                    <div class="card-icon" aria-hidden="true"></div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <button class="carousel-btn carousel-btn-next" aria-label="Next card">›</button>
    </div>
    <div class="carousel-dots">
      {carouselPrompts.map((_, index) => (
        <button class="carousel-dot" data-index={index} aria-label={`Go to card ${index + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel-section {
    background: var(--bg);
  }

  .carousel-section h2 {
    text-align: center;
    margin-bottom: 1rem;
  }

  .carousel-intro {
    text-align: center;
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: var(--ink-muted);
    max-width: 700px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .carousel-container {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .carousel-track-container {
    flex: 1;
    overflow: hidden;
    padding: 2rem 1rem;
    display: flex;
    justify-content: center;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.4s ease-in-out;
    align-items: center;
  }

  /* Tarot-style card container */
  .flip-card {
    min-width: 100%;
    max-width: 520px;
    aspect-ratio: 3 / 4;
    margin: 0 auto;
    perspective: 1000px;
    cursor: pointer;
    outline: none;
    display: flex;
    justify-content: center;
  }

  .flip-card:focus-visible {
    outline: 3px solid var(--focus);
    outline-offset: 8px;
    border-radius: 20px;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    max-width: 480px;
    transition: transform 0.6s ease;
    transform-style: preserve-3d;
  }

  .flip-card.flipped .flip-card-inner {
    transform: rotateY(180deg);
  }

  /* Double border structure */
  .card-outer {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    background: white;
    border: 4px solid white;
    border-radius: 20px;
    box-shadow: 0 8px 24px rgba(64, 32, 77, 0.15);
  }

  .card-inner {
    width: 100%;
    height: 100%;
    border: 2px solid var(--brand-1);
    border-radius: 16px;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    /* Subtle texture with radial gradient */
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 250, 246, 0.3) 0%, transparent 50%),
      #F2F1EE;
  }

  .card-front-outer .card-inner {
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 250, 246, 0.3) 0%, transparent 50%),
      #F2F1EE;
  }

  .card-back-outer {
    transform: rotateY(180deg);
  }

  .card-back-outer .card-inner {
    background:
      radial-gradient(circle at 30% 30%, rgba(83, 54, 96, 0.1) 0%, transparent 50%),
      var(--ink-2);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Card labels */
  .card-label {
    position: absolute;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand-1);
    opacity: 0.7;
  }

  .card-back-outer .card-label {
    color: rgba(255, 255, 255, 0.8);
  }

  /* Card text */
  .card-text {
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-weight: 600;
    color: var(--ink);
    text-align: center;
    margin: 0;
    line-height: 1.6;
    max-width: 100%;
  }

  .card-back-outer .card-text {
    color: white;
    font-weight: 400;
    line-height: 1.7;
  }

  /* Helper text on front */
  .card-helper {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.8125rem;
    color: var(--ink-muted);
    opacity: 0.7;
  }

  /* Icon placeholder on back */
  .card-icon {
    width: 40px;
    height: 40px;
    margin-top: 1.5rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Navigation buttons */
  .carousel-btn {
    background: var(--brand-1);
    color: white;
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, background 0.2s ease;
    flex-shrink: 0;
    font-weight: 400;
    line-height: 1;
    cursor: pointer;
  }

  .carousel-btn:hover:not(:disabled) {
    background: var(--brand-1);
    transform: scale(1.1);
  }

  .carousel-btn:disabled {
    background: var(--brand-soft);
    opacity: 0.4;
    cursor: not-allowed;
  }

  .carousel-btn:focus-visible {
    outline: 3px solid var(--focus);
    outline-offset: 3px;
  }

  /* Dot indicators */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.625rem;
    margin-top: 2rem;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: transparent;
    border: 2px solid var(--brand-1);
    padding: 0;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .carousel-dot.active {
    background: var(--brand-1);
  }

  .carousel-dot:hover {
    transform: scale(1.2);
  }

  .carousel-dot:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .carousel-track-container {
      padding: 1.5rem 0.5rem;
    }

    .flip-card {
      max-width: 400px;
    }

    .card-inner {
      padding: 2.5rem 2rem;
    }

    .card-text {
      font-size: clamp(1rem, 4vw, 1.25rem);
    }

    .carousel-btn {
      width: 36px;
      height: 36px;
      font-size: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .flip-card {
      max-width: 320px;
    }

    .card-inner {
      padding: 2rem 1.5rem;
    }
  }

  /* Reduced motion: instant reveal */
  @media (prefers-reduced-motion: reduce) {
    .flip-card-inner {
      transition: opacity 0.2s ease;
    }

    .flip-card.flipped .flip-card-inner {
      transform: none;
    }

    .flip-card.flipped .card-front-outer {
      opacity: 0;
      pointer-events: none;
    }

    .flip-card:not(.flipped) .card-back-outer {
      opacity: 0;
      pointer-events: none;
    }

    .card-back-outer {
      transform: none;
    }
  }
</style>

<script>
  // Carousel navigation
  let currentIndex = 0;
  const cards = document.querySelectorAll('.flip-card');
  const track = document.querySelector('.carousel-track') as HTMLElement;
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.querySelector('.carousel-btn-prev') as HTMLButtonElement;
  const nextBtn = document.querySelector('.carousel-btn-next') as HTMLButtonElement;

  function updateCarousel() {
    track.style.transform = `translateX(-${currentIndex * 100}%)`;

    // Update dots
    dots.forEach((dot, index) => {
      dot.classList.toggle('active', index === currentIndex);
    });

    // Update button states
    prevBtn.disabled = currentIndex === 0;
    nextBtn.disabled = currentIndex === cards.length - 1;
  }

  // Navigation buttons
  prevBtn.addEventListener('click', () => {
    if (currentIndex > 0) {
      currentIndex--;
      updateCarousel();
    }
  });

  nextBtn.addEventListener('click', () => {
    if (currentIndex < cards.length - 1) {
      currentIndex++;
      updateCarousel();
    }
  });

  // Dot navigation
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentIndex = index;
      updateCarousel();
    });
  });

  // Flip card interaction with keyboard support
  cards.forEach((card) => {
    const flipCard = (e: Event) => {
      const isFlipped = card.classList.contains('flipped');
      card.classList.toggle('flipped');
      card.setAttribute('aria-expanded', String(!isFlipped));
    };

    // Click
    card.addEventListener('click', flipCard);

    // Keyboard (Enter and Space)
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        flipCard(e);
      }
    });
  });

  // Carousel keyboard navigation (arrows)
  document.addEventListener('keydown', (e) => {
    // Only navigate if not focused on a card
    const activeElement = document.activeElement;
    if (activeElement && activeElement.classList.contains('flip-card')) {
      return;
    }

    if (e.key === 'ArrowLeft' && currentIndex > 0) {
      currentIndex--;
      updateCarousel();
    } else if (e.key === 'ArrowRight' && currentIndex < cards.length - 1) {
      currentIndex++;
      updateCarousel();
    }
  });

  // Initialize
  updateCarousel();
</script>
