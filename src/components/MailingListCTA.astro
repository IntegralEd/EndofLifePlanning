<section class="mailing-list-section">
  <div class="container">
    <div class="cta-box">
      <h2>Ready to Get Started?</h2>
      <p class="subheading">Join an upcoming workshop to clarify and document your end of life wishes.</p>
      <a href="/signup" class="btn-cta">View Upcoming Workshops</a>
    </div>
  </div>
</section>

<style>
  .mailing-list-section {
    background: var(--brand-1);
    color: white;
  }

  .cta-box {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .mailing-list-section h2 {
    color: white;
    margin-bottom: 0.75rem;
  }

  .subheading {
    font-size: 1.125rem;
    margin-bottom: 2rem;
    opacity: 0.95;
  }

  .btn-cta {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    background: var(--sage-dark);
    color: white;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .btn-cta:hover {
    background: var(--olive-dark);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .btn-cta:active {
    transform: translateY(0);
  }

  .btn-cta:focus-visible {
    outline: 3px solid rgba(255, 255, 255, 0.5);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-cta:hover {
      transform: none;
    }
  }
</style>
